---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Started - JoltGrowth">
  <main>
    <!-- Navigation -->
    <nav class="nav">
      <div class="container">
        <div class="nav-content">
          <a href="/" class="logo">
            <span class="logo-accent">JoltGrowth</span>
          </a>
          <div class="nav-links">
            <a href="/">Home</a>
            <a href="/advisors">Advisors</a>
            <a href="/blog">Blog</a>
            <a href="/get-started" class="btn-primary">Get Started</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section with Wave Animation -->
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-title">
          Let's Get <span class="gradient-text">Started</span>
        </h1>
        <p class="hero-subtitle">
          Book a call to discuss how we can accelerate your growth
        </p>

        <!-- Calendar Container -->
        <div class="calendar-container">
          <iframe src="https://api.leadconnectorhq.com/widget/booking/rxGPE2EKljoQjzNjivqC" style="width: 100%;border:none;overflow: hidden;" scrolling="no" id="rxGPE2EKljoQjzNjivqC_1765913138208"></iframe>
          <script src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>
        </div>
      </div>

      <!-- Retro Waves -->
      <div class="retro-waves">
        <canvas id="retro-wave-canvas"></canvas>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .logo-accent {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:not(.btn-primary):hover {
    color: var(--color-accent-light);
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.2s;
    border: none;
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
  }

  /* Hero Section */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    padding-bottom: 4rem;
    overflow: hidden;
    background: var(--color-bg);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1400px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem 2rem;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-light) 25%,
      #a5b4fc 50%,
      var(--color-accent-light) 75%,
      var(--color-accent) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 8s linear infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    line-height: 1.8;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Retro Waves */
  .retro-waves {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  #retro-wave-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .calendar-container {
    max-width: 1320px;
    margin: 0 auto;
    background: rgba(18, 18, 18, 0.8);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .calendar-container iframe {
    min-height: 700px;
    border-radius: 8px;
    margin-top: -3rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-links {
      gap: 1rem;
    }

    .nav-links a:not(.btn-primary) {
      display: none;
    }

    .calendar-container {
      padding: 1rem;
    }
  }
</style>

<script>
  // Retro Wave Animation
  const canvas = document.getElementById('retro-wave-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let animationId: number;
  let time = 0;

  function resizeCanvas() {
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * window.devicePixelRatio;
    canvas.height = rect.height * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  }

  function drawRetroWaves() {
    const width = canvas.width / window.devicePixelRatio;
    const height = canvas.height / window.devicePixelRatio;

    // Clear canvas
    ctx.clearRect(0, 0, width, height);

    // Perspective settings
    const horizonY = height * 0.4; // Horizon line position
    const gridLines = 40;
    const gridSpacing = 30;
    const waveDepth = 25; // Depth of perspective

    // Draw horizontal grid lines (waves)
    for (let i = 0; i < gridLines; i++) {
      const z = i / gridLines;
      const scale = 1 - z * 0.8; // Perspective scaling
      const y = horizonY + (i * gridSpacing * scale);

      if (y > height) break;

      // Wave effect with time animation - slower, flowing right
      const waveOffset = Math.sin(time * 0.0004 + i * 0.1) * 15 * scale;
      const waveOffset2 = Math.cos(time * 0.0006 + i * 0.15) * 10 * scale;

      ctx.beginPath();

      // Draw wavy line - waves flow to the right
      for (let x = 0; x <= width; x += 5) {
        const xPos = (x - width / 2) * (1 + z * 0.5) + width / 2;
        const wave = Math.sin(x * 0.008 - time * 0.0008 + i * 0.2) * waveDepth * scale + waveOffset + waveOffset2;
        const yPos = y + wave;

        if (x === 0) {
          ctx.moveTo(xPos, yPos);
        } else {
          ctx.lineTo(xPos, yPos);
        }
      }

      // Gradient color based on depth
      const alpha = 0.15 + (1 - z) * 0.35;
      const hue = 240 + z * 20; // Blue to purple gradient

      ctx.strokeStyle = `hsla(${hue}, 100%, 65%, ${alpha})`;
      ctx.lineWidth = 1 + (1 - z) * 1.5;
      ctx.stroke();
    }

    time += 20;
    animationId = requestAnimationFrame(drawRetroWaves);
  }

  // Initialize
  resizeCanvas();
  drawRetroWaves();

  // Handle resize
  window.addEventListener('resize', () => {
    resizeCanvas();
  });

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    cancelAnimationFrame(animationId);
  });
</script>

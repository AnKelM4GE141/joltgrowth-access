---
import Layout from '../layouts/Layout.astro';
---

<Layout title="JoltGrowth - Accelerate Your Business Growth">
  <main>
    <!-- Navigation -->
    <nav class="nav">
      <div class="container">
        <div class="nav-content">
          <a href="/" class="logo">
            <span class="logo-text">Jolt</span><span class="logo-accent">Growth</span>
          </a>
          <div class="nav-links">
            <a href="#services">Services</a>
            <a href="/advisors">Advisors</a>
            <a href="#contact" class="btn-primary">Get Started</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <div class="hero-badge">Growth Marketing Agency</div>
          <h1 class="hero-title">
            We build <span class="gradient-text">hands-off growth systems</span> for B2B leaders.
          </h1>
          <p class="hero-subtitle">
            We help ambitious businesses scale faster with data-driven strategies,
            automated outreach, and proven lead generation systems.
          </p>
          <div class="hero-cta">
            <a href="#contact" class="btn-primary btn-large">Start Growing Today</a>
            <a href="#services" class="btn-secondary btn-large">Explore Services</a>
          </div>
          <div class="hero-stats">
            <div class="stats-header">
              In 2024<br>we generated our clients:
            </div>
            <div class="stats-boxes">
              <div class="stat">
                <div class="stat-number">+1,110,042$</div>
                <div class="stat-label">New revenue</div>
              </div>
              <div class="stat">
                <div class="stat-number">+2,019</div>
                <div class="stat-label">Sales meetings</div>
              </div>
              <div class="stat">
                <div class="stat-number">+10,115,276$</div>
                <div class="stat-label">Sales pipelines</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="hero-gradient"></div>

      <!-- Retro Waves -->
      <div class="retro-waves">
        <canvas id="retro-wave-canvas"></canvas>
      </div>

      <!-- Ambient Light Orbs -->
      <div class="ambient-lights">
        <div class="light light-1"></div>
        <div class="light light-2"></div>
        <div class="light light-3"></div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Our Services</h2>
          <p class="section-subtitle">
            Comprehensive growth solutions tailored to your business needs
          </p>
        </div>
        <div class="services-grid">
          <div class="service-card">
            <div class="service-icon">📧</div>
            <h3 class="service-title">Cold Email Campaigns</h3>
            <p class="service-description">
              High-converting email sequences that book appointments on autopilot.
              We handle everything from copywriting to deliverability.
            </p>
            <ul class="service-features">
              <li>Custom email sequences</li>
              <li>A/B testing & optimization</li>
              <li>Inbox placement guaranteed</li>
            </ul>
          </div>
          <div class="service-card featured">
            <div class="featured-badge">Most Popular</div>
            <div class="service-icon">🎯</div>
            <h3 class="service-title">Lead Generation</h3>
            <p class="service-description">
              Targeted outreach strategies that fill your pipeline with qualified leads.
              We identify, engage, and convert your ideal customers.
            </p>
            <ul class="service-features">
              <li>Advanced audience targeting</li>
              <li>Multi-channel outreach</li>
              <li>CRM integration & tracking</li>
            </ul>
          </div>
          <div class="service-card">
            <div class="service-icon">📈</div>
            <h3 class="service-title">Growth Consulting</h3>
            <p class="service-description">
              Strategic guidance to scale your business sustainably.
              Get expert insights and actionable growth plans.
            </p>
            <ul class="service-features">
              <li>Growth strategy development</li>
              <li>Funnel optimization</li>
              <li>Performance analytics</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Approach Section -->
    <section id="approach" class="approach">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Our Approach</h2>
          <p class="section-subtitle">
            A proven process that delivers consistent results
          </p>
        </div>
        <div class="approach-steps">
          <div class="step">
            <div class="step-number">01</div>
            <h3 class="step-title">Discover & Analyze</h3>
            <p class="step-description">
              We dive deep into your business, audience, and goals to create a custom growth strategy.
            </p>
          </div>
          <div class="step">
            <div class="step-number">02</div>
            <h3 class="step-title">Build & Launch</h3>
            <p class="step-description">
              We develop and deploy campaigns with precision, ensuring every element is optimized for success.
            </p>
          </div>
          <div class="step">
            <div class="step-number">03</div>
            <h3 class="step-title">Optimize & Scale</h3>
            <p class="step-description">
              Continuous testing and refinement to maximize ROI and scale your growth exponentially.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="contact" class="cta">
      <div class="container">
        <div class="cta-content">
          <h2 class="cta-title">Ready to Accelerate Your Growth?</h2>
          <p class="cta-subtitle">
            Join hundreds of businesses that trust JoltGrowth to drive their success.
            Get started today with a free consultation.
          </p>
          <div class="cta-actions">
            <a href="mailto:hello@joltgrowth.biz" class="btn-primary btn-large">Schedule a Call</a>
            <p class="cta-note">No commitment required • Free strategy session</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="footer-brand">
            <a href="/" class="logo">
              <span class="logo-text">Jolt</span><span class="logo-accent">Growth</span>
            </a>
            <p class="footer-tagline">Accelerating business growth worldwide.</p>
          </div>
          <div class="footer-links">
            <div class="footer-column">
              <h4>Services</h4>
              <ul>
                <li><a href="#services">Cold Email</a></li>
                <li><a href="#services">Lead Generation</a></li>
                <li><a href="#services">Consulting</a></li>
              </ul>
            </div>
            <div class="footer-column">
              <h4>Company</h4>
              <ul>
                <li><a href="#approach">Our Approach</a></li>
                <li><a href="#contact">Contact</a></li>
              </ul>
            </div>
            <div class="footer-column">
              <h4>Legal</h4>
              <ul>
                <li><a href="/privacy">Privacy Policy</a></li>
                <li><a href="/terms">Terms of Service</a></li>
              </ul>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2024 JoltGrowth. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-body);
  }

  .logo-text {
    color: var(--color-text);
  }

  .logo-accent {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:not(.btn-primary):hover {
    color: var(--color-accent-light);
  }

  /* Buttons */
  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.2s;
    border: none;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
  }

  .btn-secondary {
    background: transparent;
    border: 2px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .btn-large {
    padding: 1rem 2rem;
    font-size: 1.1rem;
  }

  /* Hero Section */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding: 4rem 0;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 2rem;
    color: var(--color-accent-light);
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-light) 25%,
      #a5b4fc 50%,
      var(--color-accent-light) 75%,
      var(--color-accent) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 8s linear infinite;
    position: relative;
  }

  @keyframes shimmer {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: 3rem;
    line-height: 1.8;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 4rem;
  }

  .hero-stats {
    text-align: center;
    padding-top: 4rem;
  }

  .stats-header {
    text-align: center;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  .stats-boxes {
    display: flex;
    justify-content: center;
    align-items: stretch;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .stat {
    width: 360px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 16px;
    padding: 3rem 2rem;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px);
    text-align: center;
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 700;
    font-family: var(--font-serif);
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .stat-label {
    font-size: 1rem;
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .stats-boxes {
      flex-direction: column;
      align-items: center;
    }

    .stat {
      max-width: 100%;
      width: 100%;
    }
  }

  .hero-gradient {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 1000px;
    height: 800px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Retro Waves */
  .retro-waves {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  #retro-wave-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Ambient Light Orbs */
  .ambient-lights {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  .light {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
  }

  .light-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
    top: 5%;
    right: 10%;
    animation: drift-1 16s ease-in-out infinite;
  }

  .light-2 {
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    top: 18%;
    right: 30%;
    animation: drift-2 20s ease-in-out infinite;
  }

  .light-3 {
    width: 180px;
    height: 180px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    top: 10%;
    right: 5%;
    animation: drift-3 18s ease-in-out infinite;
  }

  @keyframes drift-1 {
    0%, 100% {
      opacity: 0.02;
      transform: translate(0, 0);
    }
    15% {
      opacity: 0.4;
    }
    25% {
      opacity: 0.4;
      transform: translate(-20px, 15px);
    }
    40% {
      opacity: 0.02;
    }
    60% {
      opacity: 0.02;
      transform: translate(-80px, 60px);
    }
    75% {
      opacity: 0.35;
      transform: translate(-60px, 40px);
    }
    85% {
      opacity: 0.02;
    }
  }

  @keyframes drift-2 {
    0%, 100% {
      opacity: 0.02;
      transform: translate(0, 0);
    }
    20% {
      opacity: 0.02;
    }
    35% {
      opacity: 0.35;
      transform: translate(50px, -30px);
    }
    50% {
      opacity: 0.02;
      transform: translate(30px, 20px);
    }
    70% {
      opacity: 0.02;
    }
    85% {
      opacity: 0.3;
      transform: translate(-40px, 50px);
    }
    95% {
      opacity: 0.02;
    }
  }

  @keyframes drift-3 {
    0%, 100% {
      opacity: 0.02;
      transform: translate(0, 0);
    }
    10% {
      opacity: 0.02;
    }
    25% {
      opacity: 0.3;
      transform: translate(-30px, 40px);
    }
    40% {
      opacity: 0.02;
    }
    55% {
      opacity: 0.02;
      transform: translate(-70px, 20px);
    }
    70% {
      opacity: 0.35;
      transform: translate(-50px, 70px);
    }
    85% {
      opacity: 0.02;
    }
  }

  /* Floating Gradient Orbs */
  .orbs-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
    mix-blend-mode: screen;
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.4) 0%, transparent 70%);
    top: 10%;
    left: -10%;
    animation: float-1 20s ease-in-out infinite;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(129, 140, 248, 0.4) 0%, transparent 70%);
    top: 60%;
    right: -5%;
    animation: float-2 25s ease-in-out infinite;
    animation-delay: -5s;
  }

  .orb-3 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, transparent 70%);
    bottom: -20%;
    left: 30%;
    animation: float-3 30s ease-in-out infinite;
    animation-delay: -10s;
  }

  @keyframes float-1 {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -30px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }

  @keyframes float-2 {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(-40px, 30px) scale(1.15);
    }
    66% {
      transform: translate(30px, -20px) scale(0.85);
    }
  }

  @keyframes float-3 {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-50px, -50px) scale(1.2);
    }
  }

  /* Services Section */
  .services {
    padding: 8rem 0;
    background: var(--color-bg-secondary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .service-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2.5rem;
    transition: all 0.3s;
  }

  .service-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .service-card.featured {
    border-color: var(--color-accent);
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.05) 0%, var(--color-bg) 100%);
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    right: 2rem;
    background: var(--color-accent);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .service-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .service-title {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .service-description {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .service-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-features li {
    padding-left: 1.5rem;
    position: relative;
    color: var(--color-text-secondary);
  }

  .service-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  /* Approach Section */
  .approach {
    padding: 8rem 0;
  }

  .approach-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .step {
    text-align: center;
  }

  .step-number {
    font-size: 4rem;
    font-weight: 800;
    font-family: var(--font-display);
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1.5rem;
    opacity: 0.5;
  }

  .step-title {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .step-description {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* CTA Section */
  .cta {
    padding: 8rem 0;
    background: var(--color-bg-secondary);
  }

  .cta-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1.5rem;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 3rem;
    line-height: 1.8;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-note {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  /* Footer */
  .footer {
    padding: 4rem 0 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-brand {
    max-width: 300px;
  }

  .footer-tagline {
    margin-top: 1rem;
    color: var(--color-text-secondary);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-column h4 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    color: var(--color-text-secondary);
  }

  .footer-column ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-column a {
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .footer-column a:hover {
    color: var(--color-accent-light);
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-links {
      gap: 1rem;
    }

    .nav-links a:not(.btn-primary) {
      display: none;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .approach-steps {
      grid-template-columns: 1fr;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Retro Wave Animation
  const canvas = document.getElementById('retro-wave-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let animationId: number;
  let time = 0;

  function resizeCanvas() {
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * window.devicePixelRatio;
    canvas.height = rect.height * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  }

  function drawRetroWaves() {
    const width = canvas.width / window.devicePixelRatio;
    const height = canvas.height / window.devicePixelRatio;

    // Clear canvas
    ctx.clearRect(0, 0, width, height);

    // Perspective settings
    const horizonY = height * 0.4; // Horizon line position
    const gridLines = 40;
    const gridSpacing = 30;
    const waveDepth = 25; // Depth of perspective

    // Draw horizontal grid lines (waves)
    for (let i = 0; i < gridLines; i++) {
      const z = i / gridLines;
      const scale = 1 - z * 0.8; // Perspective scaling
      const y = horizonY + (i * gridSpacing * scale);

      if (y > height) break;

      // Wave effect with time animation - slower, flowing right
      const waveOffset = Math.sin(time * 0.0004 + i * 0.1) * 15 * scale;
      const waveOffset2 = Math.cos(time * 0.0006 + i * 0.15) * 10 * scale;

      ctx.beginPath();

      // Draw wavy line - waves flow to the right
      for (let x = 0; x <= width; x += 5) {
        const xPos = (x - width / 2) * (1 + z * 0.5) + width / 2;
        const wave = Math.sin(x * 0.008 - time * 0.0008 + i * 0.2) * waveDepth * scale + waveOffset + waveOffset2;
        const yPos = y + wave;

        if (x === 0) {
          ctx.moveTo(xPos, yPos);
        } else {
          ctx.lineTo(xPos, yPos);
        }
      }

      // Gradient color based on depth
      const alpha = 0.15 + (1 - z) * 0.35;
      const hue = 240 + z * 20; // Blue to purple gradient

      // Add white glow effect
      ctx.shadowColor = 'rgba(255, 255, 255, 0.5)';
      ctx.shadowBlur = 8 + (1 - z) * 12;

      ctx.strokeStyle = `hsla(${hue}, 100%, 65%, ${alpha})`;
      ctx.lineWidth = 1 + (1 - z) * 1.5;
      ctx.stroke();

      // Reset shadow for next iteration
      ctx.shadowBlur = 0;
    }

    time += 20;
    animationId = requestAnimationFrame(drawRetroWaves);
  }

  // Initialize
  resizeCanvas();
  drawRetroWaves();

  // Handle resize
  window.addEventListener('resize', () => {
    resizeCanvas();
  });

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    cancelAnimationFrame(animationId);
  });
</script>

    min-height: 600px;
  }

  .phone-mockup {
    position: relative;
    z-index: 2;
    max-width: 500px;
  }

  .phone-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 40px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .floating-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.6;
    animation: float-slow 8s ease-in-out infinite;
  }

  .orb-blue-1 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, #3b82f6 0%, transparent 70%);
    top: 10%;
    left: 10%;
    animation-delay: 0s;
  }

  .orb-blue-2 {
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, #2563eb 0%, transparent 70%);
    bottom: 30%;
    left: 5%;
    animation-delay: 2s;
  }

  .orb-purple-1 {
    width: 180px;
    height: 180px;
    background: radial-gradient(circle, #d946ef 0%, transparent 70%);
    top: 15%;
    right: 15%;
    animation-delay: 1s;
  }

  .orb-purple-2 {
    width: 160px;
    height: 160px;
    background: radial-gradient(circle, #a855f7 0%, transparent 70%);
    bottom: 20%;
    right: 10%;
    animation-delay: 3s;
  }

  @keyframes float-slow {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(10px, -10px) scale(1.05);
    }
    50% {
      transform: translate(-10px, 10px) scale(0.95);
    }
    75% {

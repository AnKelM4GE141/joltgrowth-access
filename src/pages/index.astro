  /* Comparison Table Section */
  .comparison-table {
    padding: 6rem 0;
    background: transparent;
    position: relative;
  }

  .comparison-table-title {
    font-size: clamp(2rem, 5vw, 3rem);
    text-align: center;
    margin-bottom: 4rem;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .options-table {

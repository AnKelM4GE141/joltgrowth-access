---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Explore Services - JoltGrowth">
  <main>
    <!-- Navigation -->
    <nav class="nav">
      <div class="container">
        <div class="nav-content">
          <a href="/" class="logo">
            <span class="logo-accent">JoltGrowth</span>
          </a>
          <div class="nav-links">
            <a href="/advisors">Advisors</a>
            <a href="/blog">Blog</a>
            <a href="/get-started" class="btn-primary">Get Started</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section with Wave Animation -->
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-title">
          Explore our <span class="gradient-text">Services</span>
        </h1>
        <p class="hero-subtitle">
          Choose the path that accelerates your growth
        </p>

        <!-- Services Grid -->
        <div class="services-grid">
          <!-- Service 1: Acquisition Consulting -->
          <div class="service-card" data-expandable>
            <div class="service-image roman-1">
              <div class="roman-icon">🤴</div>
              <div class="roman-overlay"></div>
            </div>
            <div class="service-content">
              <h3 class="service-title">Acquisition Consulting</h3>
              <p class="service-description">Strategic guidance to conquer your market with precision and power.</p>
              <div class="service-expanded">
                <p>Our acquisition consulting service provides comprehensive strategic guidance for businesses looking to dominate their market. We analyze your current position, identify growth opportunities, and create actionable plans to capture market share efficiently. With data-driven insights and battle-tested strategies, we help you make informed decisions that lead to sustainable growth and competitive advantage.</p>
              </div>
              <div class="expand-indicator">▼</div>
            </div>
          </div>

          <!-- Service 2: Power Offer Paid Ads -->
          <div class="service-card" data-expandable>
            <div class="service-image roman-2">
              <div class="roman-icon">👑</div>
              <div class="roman-overlay"></div>
            </div>
            <div class="service-content">
              <h3 class="service-title">Power Offer Paid Ads</h3>
              <p class="service-description">Dominate your advertising with offers that command attention and results.</p>
              <div class="service-expanded">
                <p>Transform your paid advertising campaigns with irresistible power offers that cut through the noise. We craft compelling ad campaigns across Google, Facebook, LinkedIn, and other platforms, combining creative excellence with conversion-focused strategies. Our approach maximizes ROI by targeting the right audience with messages that resonate and drive action, turning ad spend into profitable revenue streams.</p>
              </div>
              <div class="expand-indicator">▼</div>
            </div>
          </div>

          <!-- Service 3: B2B Predictable Pipeline -->
          <div class="service-card" data-expandable>
            <div class="service-image roman-3">
              <div class="roman-icon">🏛️</div>
              <div class="roman-overlay"></div>
            </div>
            <div class="service-content">
              <h3 class="service-title">B2B Predictable Pipeline</h3>
              <p class="service-description">Build an empire of consistent, qualified leads flowing to your business.</p>
              <div class="service-expanded">
                <p>Establish a systematic, predictable pipeline of qualified B2B leads that consistently fills your sales calendar. We implement automated outreach systems, pain-focused targeting, and proven follow-up sequences that generate meetings with decision-makers. Our methodology removes the uncertainty from lead generation, providing you with a reliable stream of opportunities month after month while your team focuses on closing deals.</p>
              </div>
              <div class="expand-indicator">▼</div>
            </div>
          </div>

          <!-- Service 4: Free Stuff -->
          <div class="service-card" data-expandable>
            <div class="service-image roman-4">
              <div class="roman-icon">🏆</div>
              <div class="roman-overlay"></div>
            </div>
            <div class="service-content">
              <h3 class="service-title">Free Stuff</h3>
              <p class="service-description">Valuable resources and tools to strengthen your growth arsenal.</p>
              <div class="service-expanded">
                <p>Access our collection of free resources, templates, and tools designed to accelerate your growth journey. From our GTM frameworks and cold email templates to strategic guides and assessment tools, we provide actionable content that delivers real value. These resources represent the same methodologies we use with our clients, available to help you implement proven strategies on your own timeline.</p>
              </div>
              <div class="expand-indicator">▼</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Retro Waves -->
      <div class="retro-waves">
        <canvas id="retro-wave-canvas"></canvas>
      </div>
    </section>

    <!-- Calendar Section -->
    <section class="calendar-section">
      <div class="container">
        <h2 class="calendar-heading">Ready to Get Started?</h2>
        <p class="calendar-subheading">Book a call to discuss which service is right for you</p>
        <div class="calendar-container">
          <iframe src="https://api.leadconnectorhq.com/widget/booking/rxGPE2EKljoQjzNjivqC" style="width: 100%;border:none;overflow: hidden;" scrolling="no" id="rxGPE2EKljoQjzNjivqC_1765913138208"></iframe>
          <script src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .logo-accent {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:not(.btn-primary):hover {
    color: var(--color-accent-light);
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.2s;
    border: none;
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
  }

  /* Hero Section */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    padding-bottom: 4rem;
    overflow: hidden;
    background: var(--color-bg);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem 2rem 4rem;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-light) 25%,
      #a5b4fc 50%,
      var(--color-accent-light) 75%,
      var(--color-accent) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 8s linear infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    max-width: 700px;
    margin: 0 auto 3rem;
  }

  /* Retro Waves */
  .retro-waves {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  #retro-wave-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .service-card {
    background: var(--color-bg-secondary);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: all 0.3s;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  .service-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-accent);
    box-shadow: 0 20px 40px rgba(99, 102, 241, 0.2);
  }

  .service-card.expanded {
    transform: none;
  }

  .service-content {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .service-image {
    position: relative;
    width: 100%;
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Roman-inspired backgrounds */
  .roman-1 {
    background: linear-gradient(135deg, #A9A9A9 0%, #E8E8E8 50%, #A9A9A9 100%);
  }

  .roman-2 {
    background: linear-gradient(135deg, #B0B0B0 0%, #D3D3D3 50%, #B0B0B0 100%);
  }

  .roman-3 {
    background: linear-gradient(135deg, #949494 0%, #C0C0C0 50%, #949494 100%);
  }

  .roman-4 {
    background: linear-gradient(135deg, #A9A9A9 0%, #BEBEBE 50%, #A9A9A9 100%);
  }

  .roman-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 30%, rgba(0, 0, 0, 0.4) 100%);
  }

  .roman-icon {
    font-size: 6rem;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
  }

  .service-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 1.5rem 2rem 1rem;
    font-family: var(--font-display);
    color: var(--color-text);
  }

  .service-description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 2rem 1rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .service-expanded {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease-out, margin 0.4s ease-out;
    margin: 0 2rem;
  }

  .service-card.expanded .service-expanded {
    max-height: 500px;
    margin: 0 2rem 1rem;
  }

  .service-expanded p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .expand-indicator {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-accent);
    padding: 0.5rem 2rem 1.5rem;
    transition: transform 0.3s;
    user-select: none;
  }

  .service-card.expanded .expand-indicator {
    transform: rotate(180deg);
  }

  /* Calendar Section */
  .calendar-section {
    padding: 4rem 0 6rem;
    background: var(--color-bg);
  }

  .calendar-heading {
    font-size: clamp(2rem, 5vw, 3rem);
    text-align: center;
    margin-bottom: 1rem;
  }

  .calendar-subheading {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    text-align: center;
    margin-bottom: 3rem;
  }

  .calendar-container {
    max-width: 1320px;
    margin: 0 auto;
    background: rgba(18, 18, 18, 0.8);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .calendar-container iframe {
    min-height: 700px;
    border-radius: 8px;
    margin-top: -3rem;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 1rem;
    }

    .nav-links a:not(.btn-primary) {
      display: none;
    }

    .service-image {
      height: 250px;
    }

    .roman-icon {
      font-size: 4rem;
    }
  }
</style>

<script>
  // Retro Wave Animation
  const canvas = document.getElementById('retro-wave-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let animationId: number;
  let time = 0;

  function resizeCanvas() {
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * window.devicePixelRatio;
    canvas.height = rect.height * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  }

  function drawRetroWaves() {
    const width = canvas.width / window.devicePixelRatio;
    const height = canvas.height / window.devicePixelRatio;

    // Clear canvas
    ctx.clearRect(0, 0, width, height);

    // Perspective settings
    const horizonY = height * 0.4;
    const gridLines = 40;
    const gridSpacing = 30;
    const waveDepth = 25;

    // Draw horizontal grid lines (waves)
    for (let i = 0; i < gridLines; i++) {
      const z = i / gridLines;
      const scale = 1 - z * 0.8;
      const y = horizonY + (i * gridSpacing * scale);

      if (y > height) break;

      const waveOffset = Math.sin(time * 0.0004 + i * 0.1) * 15 * scale;
      const waveOffset2 = Math.cos(time * 0.0006 + i * 0.15) * 10 * scale;

      ctx.beginPath();

      for (let x = 0; x <= width; x += 5) {
        const xPos = (x - width / 2) * (1 + z * 0.5) + width / 2;
        const wave = Math.sin(x * 0.008 - time * 0.0008 + i * 0.2) * waveDepth * scale + waveOffset + waveOffset2;
        const yPos = y + wave;

        if (x === 0) {
          ctx.moveTo(xPos, yPos);
        } else {
          ctx.lineTo(xPos, yPos);
        }
      }

      const alpha = 0.15 + (1 - z) * 0.35;
      const hue = 240 + z * 20;

      ctx.strokeStyle = `hsla(${hue}, 100%, 65%, ${alpha})`;
      ctx.lineWidth = 1 + (1 - z) * 1.5;
      ctx.stroke();
    }

    time += 20;
    animationId = requestAnimationFrame(drawRetroWaves);
  }

  // Initialize
  resizeCanvas();
  drawRetroWaves();

  // Handle resize
  window.addEventListener('resize', () => {
    resizeCanvas();
  });

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    cancelAnimationFrame(animationId);
  });

  // Service card expand/collapse functionality
  document.querySelectorAll('[data-expandable]').forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('expanded');
    });
  });
</script>

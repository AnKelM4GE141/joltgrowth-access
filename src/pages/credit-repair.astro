---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Credit Repair Solutions - JoltGrowth" description="Explore financing options tailored to your business needs and credit situation.">
  <main>
    <!-- Navigation -->
    <nav class="nav">
      <div class="container">
        <div class="nav-content">
          <a href="/" class="logo">
            <img src="/logo.png" alt="JoltGrowth" class="logo-image" />
            <span class="logo-text">Jolt</span><span class="logo-accent">Growth</span>
          </a>
          <div class="nav-links">
            <a href="/advisors">Our Team</a>
            <a href="/blog">Blog</a>
            <a href="/get-started" class="btn-primary">Get Started</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <h1 class="hero-title">Credit Repair & <span class="gradient-text">Funding Solutions</span></h1>
          <p class="hero-subtitle">
            Access the capital you need to grow your business, regardless of your current credit situation.
            We help you find the right financing solution tailored to your unique needs.
          </p>
        </div>
      </div>
    </section>

    <!-- Loan Options Section -->
    <section class="loan-options">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Financing Options</h2>
          <p class="section-subtitle">Choose the solution that fits your business needs</p>
        </div>

        <div class="loans-grid">
          <!-- SBA Loan -->
          <div class="loan-card">
            <div class="loan-icon">🏦</div>
            <h3 class="loan-title">SBA Loan</h3>
            <p class="loan-subheading">Government-Backed Funding for Established Businesses</p>
            <p class="loan-description">
              Perfect for businesses with at least 2 years of operating history and steady revenue. SBA loans offer
              the lowest interest rates and longest repayment terms available. If you're looking to expand operations,
              purchase equipment, or refinance existing debt, this is your most cost-effective option. While the
              application process is more thorough, the savings over the loan term make it worthwhile for businesses
              with solid financials and a credit score above 650.
            </p>
            <div class="loan-highlights">
              <div class="highlight-item">
                <span class="highlight-label">Amount:</span>
                <span class="highlight-value">Up to $5M</span>
              </div>
              <div class="highlight-item">
                <span class="highlight-label">Terms:</span>
                <span class="highlight-value">10-25 years</span>
              </div>
              <div class="highlight-item">
                <span class="highlight-label">Rate:</span>
                <span class="highlight-value">6-9% APR</span>
              </div>
            </div>
            <a href="#contact" class="loan-cta">Learn More →</a>
          </div>

          <!-- Business Line of Credit -->
          <div class="loan-card featured">
            <div class="featured-badge">Most Flexible</div>
            <div class="loan-icon">💳</div>
            <h3 class="loan-title">Business Line of Credit</h3>
            <p class="loan-subheading">Revolving Credit for Cash Flow Management</p>
            <p class="loan-description">
              Ideal for businesses experiencing seasonal fluctuations or needing quick access to capital for
              unexpected opportunities. You only pay interest on what you use, and funds become available again
              as you pay down the balance. This is perfect if you're struggling with inconsistent cash flow, need
              to cover payroll gaps, or want a safety net for emergencies. With approval in as little as 48 hours,
              you can solve immediate cash crunches while building business credit for future needs.
            </p>
            <div class="loan-highlights">
              <div class="highlight-item">
                <span class="highlight-label">Amount:</span>
                <span class="highlight-value">$10K-$250K</span>
              </div>
              <div class="highlight-item">
                <span class="highlight-label">Terms:</span>
                <span class="highlight-value">Revolving</span>
              </div>
              <div class="highlight-item">
                <span class="highlight-label">Rate:</span>
                <span class="highlight-value">8-25% APR</span>
              </div>
            </div>
            <a href="#contact" class="loan-cta">Learn More →</a>
          </div>

          <!-- Credit Stacking -->
          <div class="loan-card">
            <div class="loan-icon">📊</div>
            <h3 class="loan-title">Credit Stacking</h3>
            <p class="loan-subheading">Multiple Credit Sources for Maximum Funding</p>
            <p class="loan-description">
              The solution when traditional lenders say no or can't provide enough capital. We help you secure
              multiple business credit cards and lines of credit simultaneously, often totaling $50K-$250K in
              available funding. Perfect for startups, businesses with limited credit history, or those who need
              capital fast without collateral. You'll build strong business credit while accessing 0% APR
              promotional periods on many cards. This strategy works even if your personal credit is under 680,
              as we leverage your business profile to qualify.
            </p>
            <div class="loan-highlights">
              <div class="highlight-item">
                <span class="highlight-label">Amount:</span>
                <span class="highlight-value">$50K-$250K</span>
              </div>
              <div class="highlight-item">
                <span class="highlight-label">Terms:</span>
                <span class="highlight-value">Varies</span>
              </div>
              <div class="highlight-item">
                <span class="highlight-label">Rate:</span>
                <span class="highlight-value">0-24% APR</span>
              </div>
            </div>
            <a href="#contact" class="loan-cta">Learn More →</a>
          </div>

          <!-- Business Term Loan -->
          <div class="loan-card">
            <div class="loan-icon">💰</div>
            <h3 class="loan-title">Business Term Loan</h3>
            <p class="loan-subheading">Fast Capital with Flexible Requirements</p>
            <p class="loan-description">
              When you need significant capital quickly and don't qualify for SBA financing, term loans bridge
              the gap. Designed for businesses doing at least $100K in annual revenue who need to invest in
              growth now—whether that's hiring, inventory, marketing, or equipment. Unlike SBA loans, approval
              takes days not months, and credit requirements are more forgiving. Yes, rates are higher, but the
              speed and accessibility make it worthwhile when you're leaving money on the table by not acting
              fast. Fixed payments make budgeting simple, and there's no need to put up personal collateral in most cases.
            </p>
            <div class="loan-highlights">
              <div class="highlight-item">
                <span class="highlight-label">Amount:</span>
                <span class="highlight-value">$25K-$500K</span>
              </div>
              <div class="highlight-item">
                <span class="highlight-label">Terms:</span>
                <span class="highlight-value">6 months-5 years</span>
              </div>
              <div class="highlight-item">
                <span class="highlight-label">Rate:</span>
                <span class="highlight-value">10-30% APR</span>
              </div>
            </div>
            <a href="#contact" class="loan-cta">Learn More →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
      <div class="container">
        <div class="cta-content">
          <h2 class="cta-title">Ready to Get Funded?</h2>
          <p class="cta-subtitle">
            Let's discuss which financing option is best for your business situation.
            Schedule a free consultation to explore your options.
          </p>
          <div class="cta-actions">
            <a href="mailto:hello@joltgrowth.biz" class="btn-primary btn-large">Schedule Consultation</a>
            <p class="cta-note">No commitment required • Free expert advice</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="footer-brand">
            <a href="/" class="logo">
              <img src="/logo.png" alt="JoltGrowth" class="logo-image" />
              <span class="logo-text">Jolt</span><span class="logo-accent">Growth</span>
            </a>
            <p class="footer-tagline">Accelerating business growth worldwide.</p>
          </div>
          <div class="footer-links">
            <div class="footer-column">
              <h4>Services</h4>
              <ul>
                <li><a href="/#services">Cold Email</a></li>
                <li><a href="/#services">Lead Generation</a></li>
                <li><a href="/#services">Consulting</a></li>
                <li><a href="/referral-partners">Join Our referral partners</a></li>
              </ul>
            </div>
            <div class="footer-column">
              <h4>Company</h4>
              <ul>
                <li><a href="/about">About Us</a></li>
                <li><a href="/advisors">Our Team</a></li>
                <li><a href="/#contact">Contact</a></li>
              </ul>
            </div>
            <div class="footer-column">
              <h4>Legal</h4>
              <ul>
                <li><a href="/privacy">Privacy Policy</a></li>
                <li><a href="/terms">Terms of Service</a></li>
              </ul>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2024 JoltGrowth. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-image {
    height: 40px;
    width: auto;
  }

  .logo-text {
    color: var(--color-text);
  }

  .logo-accent {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:not(.btn-primary):hover {
    color: var(--color-accent-light);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.2s;
    border: none;
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
  }

  .btn-large {
    padding: 1rem 2rem;
    font-size: 1.1rem;
  }

  /* Hero Section */
  .hero {
    padding: 12rem 0 6rem;
    background: var(--color-bg);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-light) 25%,
      #a5b4fc 50%,
      var(--color-accent-light) 75%,
      var(--color-accent) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 8s linear infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  /* Loan Options Section */
  .loan-options {
    padding: 8rem 0;
    background: var(--color-bg-secondary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
  }

  .loans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .loan-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 2.5rem;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
  }

  .loan-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .loan-card.featured {
    border-color: var(--color-accent);
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.05) 0%, var(--color-bg) 100%);
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    right: 2rem;
    background: var(--color-accent);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .loan-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .loan-title {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .loan-subheading {
    font-size: 1rem;
    color: var(--color-accent-light);
    font-weight: 600;
    margin-bottom: 1.5rem;
    line-height: 1.4;
  }

  .loan-description {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 2rem;
    flex: 1;
  }

  .loan-highlights {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .highlight-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .highlight-label {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  .highlight-value {
    font-size: 1rem;
    color: var(--color-accent-light);
    font-weight: 700;
  }

  .loan-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.5rem;
    background: transparent;
    border: 2px solid var(--color-accent);
    border-radius: 0.5rem;
    color: var(--color-accent);
    font-weight: 600;
    transition: all 0.2s;
    text-align: center;
  }

  .loan-cta:hover {
    background: var(--color-accent);
    color: white;
    transform: translateY(-2px);
  }

  /* CTA Section */
  .cta {
    padding: 8rem 0;
    background: var(--color-bg);
  }

  .cta-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1.5rem;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 3rem;
    line-height: 1.8;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-note {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  /* Footer */
  .footer {
    padding: 4rem 0 2rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-brand {
    max-width: 300px;
  }

  .footer-tagline {
    margin-top: 1rem;
    color: var(--color-text-secondary);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-column h4 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    color: var(--color-text-secondary);
  }

  .footer-column ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-column a {
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }

  .footer-column a:hover {
    color: var(--color-accent-light);
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-links a:not(.btn-primary) {
      display: none;
    }

    .loans-grid {
      grid-template-columns: 1fr;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Blog - JoltGrowth">
  <main>
    <!-- Navigation -->
    <nav class="nav">
      <div class="container">
        <div class="nav-content">
          <a href="/" class="logo">
            <span class="logo-accent">JoltGrowth</span>
          </a>
          <div class="nav-links">
            <a href="/advisors">Advisors</a>
            <a href="/blog">Blog</a>
            <a href="/get-started" class="btn-primary">Get Started</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section with Wave Animation -->
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-title">
          <span class="gradient-text">Blog</span>
        </h1>
        <p class="hero-subtitle">
          Insights, strategies, and ideas for accelerating growth
        </p>
      </div>

      <!-- Retro Waves -->
      <div class="retro-waves">
        <canvas id="retro-wave-canvas"></canvas>
      </div>
    </section>

    <!-- Blog Posts Section -->
    <section class="blog-posts">
      <div class="container">
        <div class="posts-grid">

          <!-- Blog Post 1 -->
          <a href="/blog/pain-first-marketing" class="post-card">
            <div class="post-date">December 15, 2024</div>
            <h2 class="post-title">Why Pain-First Marketing Wins in B2B</h2>
            <p class="post-excerpt">Most B2B companies target personas. We target pain. Here's why this simple shift changes everything about your go-to-market strategy.</p>
            <div class="post-meta">
              <span class="read-time">5 min read</span>
              <span class="post-arrow">→</span>
            </div>
          </a>

          <!-- Blog Post 2 -->
          <a href="/blog/predictable-pipeline" class="post-card">
            <div class="post-date">December 10, 2024</div>
            <h2 class="post-title">Building a Predictable Pipeline: The System</h2>
            <p class="post-excerpt">Stop relying on hope and luck. Learn the exact system we use to generate consistent, qualified leads month after month.</p>
            <div class="post-meta">
              <span class="read-time">7 min read</span>
              <span class="post-arrow">→</span>
            </div>
          </a>

          <!-- Blog Post 3 -->
          <a href="/blog/cold-email-that-works" class="post-card">
            <div class="post-date">December 5, 2024</div>
            <h2 class="post-title">Cold Email That Actually Works in 2024</h2>
            <p class="post-excerpt">Generic templates are dead. Discover the framework for writing cold emails that get responses and book meetings.</p>
            <div class="post-meta">
              <span class="read-time">6 min read</span>
              <span class="post-arrow">→</span>
            </div>
          </a>

          <!-- Blog Post 4 -->
          <a href="/blog/scaling-without-headcount" class="post-card">
            <div class="post-date">November 28, 2024</div>
            <h2 class="post-title">Scaling Outreach Without Adding Headcount</h2>
            <p class="post-excerpt">The traditional SDR model is broken. Here's how to achieve unlimited scale with systems instead of headcount.</p>
            <div class="post-meta">
              <span class="read-time">8 min read</span>
              <span class="post-arrow">→</span>
            </div>
          </a>

          <!-- Blog Post 5 -->
          <a href="/blog/power-offer-framework" class="post-card">
            <div class="post-date">November 20, 2024</div>
            <h2 class="post-title">The Power Offer Framework</h2>
            <p class="post-excerpt">Your offer determines your success. Learn how to craft irresistible offers that sell themselves.</p>
            <div class="post-meta">
              <span class="read-time">10 min read</span>
              <span class="post-arrow">→</span>
            </div>
          </a>

          <!-- Blog Post 6 -->
          <a href="/blog/antifragile-gtm" class="post-card">
            <div class="post-date">November 15, 2024</div>
            <h2 class="post-title">The Antifragile GTM Thesis</h2>
            <p class="post-excerpt">Most go-to-market strategies break under pressure. Ours gets stronger. Here's the philosophy behind our approach.</p>
            <div class="post-meta">
              <span class="read-time">12 min read</span>
              <span class="post-arrow">→</span>
            </div>
          </a>

        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-body);
  }

  .logo-accent {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:not(.btn-primary):hover {
    color: var(--color-accent-light);
  }

  .btn-primary {
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
  }

  /* Hero Section */
  .hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    overflow: hidden;
    background: var(--color-bg);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding: 4rem 2rem;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .gradient-text {
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      var(--color-accent-light) 25%,
      #a5b4fc 50%,
      var(--color-accent-light) 75%,
      var(--color-accent) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 8s linear infinite;
  }

  @keyframes shimmer {
    0% { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
  }

  /* Retro Waves */
  .retro-waves {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  #retro-wave-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Blog Posts Section */
  .blog-posts {
    padding: 6rem 0;
    background: var(--color-bg);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .post-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 12px 24px rgba(99, 102, 241, 0.15);
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    font-family: var(--font-display);
    color: var(--color-text);
  }

  .post-excerpt {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .post-arrow {
    font-size: 1.25rem;
    color: var(--color-accent);
    transition: transform 0.3s;
  }

  .post-card:hover .post-arrow {
    transform: translateX(4px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-links a:not(.btn-primary) {
      display: none;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Retro Wave Animation
  const canvas = document.getElementById('retro-wave-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let animationId: number;
  let time = 0;

  function resizeCanvas() {
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * window.devicePixelRatio;
    canvas.height = rect.height * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  }

  function drawRetroWaves() {
    const width = canvas.width / window.devicePixelRatio;
    const height = canvas.height / window.devicePixelRatio;

    ctx.clearRect(0, 0, width, height);

    const horizonY = height * 0.4;
    const gridLines = 40;
    const gridSpacing = 30;
    const waveDepth = 25;

    for (let i = 0; i < gridLines; i++) {
      const z = i / gridLines;
      const scale = 1 - z * 0.8;
      const y = horizonY + (i * gridSpacing * scale);

      if (y > height) break;

      const waveOffset = Math.sin(time * 0.0004 + i * 0.1) * 15 * scale;
      const waveOffset2 = Math.cos(time * 0.0006 + i * 0.15) * 10 * scale;

      ctx.beginPath();

      for (let x = 0; x <= width; x += 5) {
        const xPos = (x - width / 2) * (1 + z * 0.5) + width / 2;
        const wave = Math.sin(x * 0.008 - time * 0.0008 + i * 0.2) * waveDepth * scale + waveOffset + waveOffset2;
        const yPos = y + wave;

        if (x === 0) {
          ctx.moveTo(xPos, yPos);
        } else {
          ctx.lineTo(xPos, yPos);
        }
      }

      const alpha = 0.15 + (1 - z) * 0.35;
      const hue = 240 + z * 20;

      ctx.strokeStyle = `hsla(${hue}, 100%, 65%, ${alpha})`;
      ctx.lineWidth = 1 + (1 - z) * 1.5;
      ctx.stroke();
    }

    time += 20;
    animationId = requestAnimationFrame(drawRetroWaves);
  }

  resizeCanvas();
  drawRetroWaves();

  window.addEventListener('resize', () => {
    resizeCanvas();
  });

  window.addEventListener('beforeunload', () => {
    cancelAnimationFrame(animationId);
  });
</script>
